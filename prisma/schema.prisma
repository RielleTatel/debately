generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationRole {
  OWNER
  MEMBER

  @@map("organization_role")
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  displayName        String   @map("display_name")
  avatarUrl          String?  @map("avatar_url")
  emailNotifications Json     @default("{\"announcements\":true,\"paymentUpdates\":true,\"requestUpdates\":true}") @map("email_notifications")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  ownedOrganizations      Organization[]         @relation("OrganizationOwner")
  memberships             OrganizationMember[]
  tournamentDirectorships TournamentDirector[]
  csvImportsUploaded      CsvImport[]
  institutionClaims       InstitutionClaim[]
  uploadedReceipts        PaymentReceipt[]       @relation("ReceiptUploader")
  verifiedReceipts        PaymentReceipt[]       @relation("ReceiptVerifier")
  invoiceOverrides        Invoice[]              @relation("InvoiceOverrideBy")
  sentReminders           PaymentReminderLog[]   @relation("ReminderSender")
  announcementsAuthored   Announcement[]         @relation("AnnouncementAuthor")
  announcementsRead       AnnouncementRead[]     @relation("AnnouncementReader")
  requestsSubmitted       Request[]              @relation("RequestSubmitter")
  requestsResolved        Request[]              @relation("RequestResolver")
  requestActivities       RequestActivity[]      @relation("RequestActor")
  activityLogEntries      ActivityLog[]          @relation("ActivityActor")
  emailPreferences        UserEmailPreference?

  @@map("profiles")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  description String?
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner           Profile                    @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members         OrganizationMember[]
  aliases         OrganizationSlugAlias[]
  invitations     OrganizationInvitation[]
  tournaments     Tournament[]
  columnMappings  ColumnMapping[]
  activityLog     ActivityLog[]

  @@index([ownerId])
  @@map("organizations")
}

model OrganizationMember {
  id        String           @id @default(cuid())
  orgId     String           @map("org_id")
  profileId String           @map("profile_id")
  role      OrganizationRole
  joinedAt  DateTime         @default(now()) @map("joined_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([orgId, profileId])
  @@index([profileId])
  @@map("organization_members")
}

model OrganizationSlugAlias {
  oldSlug   String   @id @map("old_slug")
  orgId     String   @map("org_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([expiresAt])
  @@map("organization_slug_aliases")
}

model OrganizationInvitation {
  id         String           @id @default(cuid())
  orgId      String           @map("org_id")
  email      String
  token      String           @unique
  role       OrganizationRole
  expiresAt  DateTime         @map("expires_at")
  acceptedAt DateTime?        @map("accepted_at")
  revokedAt  DateTime?        @map("revoked_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@map("organization_invitations")
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("tournament_status")
}

enum DebateFormat {
  BP
  AP
  WSDC
  CP
  CUSTOM

  @@map("debate_format")
}

enum ScheduleEntryKind {
  DEADLINE
  ROUND
  CEREMONY
  BREAK
  OTHER

  @@map("schedule_entry_kind")
}

model Tournament {
  id                           String           @id @default(cuid())
  orgId                        String           @map("org_id")
  name                         String
  slug                         String
  format                       DebateFormat
  status                       TournamentStatus @default(DRAFT)
  startDate                    DateTime         @map("start_date")
  endDate                      DateTime         @map("end_date")
  registrationDeadline         DateTime         @map("registration_deadline")
  paymentDeadline              DateTime?        @map("payment_deadline")
  venue                        String
  address                      String
  maxTeamSlots                 Int              @map("max_team_slots")
  description                  String?
  logoUrl                      String?          @map("logo_url")
  rulesUrl                     String?          @map("rules_url")
  feeStructure                 Json             @default("{\"kind\":\"none\",\"lines\":[]}") @map("fee_structure")
  currency                     String           @default("USD")
  formatConfig                 Json             @default("{\"speakerCount\":3,\"customEligibility\":\"\"}") @map("format_config")
  registrationOpen             Boolean          @default(false) @map("registration_open")
  maxTeamsPerInstitution       Int?             @map("max_teams_per_institution")
  maxAdjudicatorsPerInstitution Int?            @map("max_adjudicators_per_institution")
  portalActive                 Boolean          @default(false) @map("portal_active")
  publicPageEnabled            Boolean          @default(false) @map("public_page_enabled")
  archivedAt                   DateTime?        @map("archived_at")
  createdAt                    DateTime         @default(now()) @map("created_at")
  updatedAt                    DateTime         @updatedAt @map("updated_at")

  organization        Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  directors              TournamentDirector[]
  schedule               TournamentScheduleEntry[]
  institutions           TournamentInstitution[]
  institutionAliases     InstitutionAlias[]
  adjudicators           Adjudicator[]
  csvImports             CsvImport[]
  announcements          Announcement[]
  requests               Request[]
  activityLog            ActivityLog[]
  publicAssets           TournamentPublicAsset[]
  contacts               TournamentContact[]
  publicContactMessages  PublicContactMessage[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([status])
  @@map("tournaments")
}

model TournamentDirector {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  profileId    String   @map("profile_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, profileId])
  @@index([profileId])
  @@map("tournament_directors")
}

model TournamentScheduleEntry {
  id           String            @id @default(cuid())
  tournamentId String            @map("tournament_id")
  label        String
  kind         ScheduleEntryKind
  startAt      DateTime          @map("start_at")
  endAt        DateTime?         @map("end_at")
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, startAt])
  @@map("tournament_schedule_entries")
}

enum CsvImportStatus {
  STAGING
  PROCESSED
  FINALIZED
  ROLLED_BACK

  @@map("csv_import_status")
}

enum CsvImportRowStatus {
  PENDING
  ERROR
  WARNING
  IMPORTED
  SKIPPED
  RESUBMISSION

  @@map("csv_import_row_status")
}

enum AdjudicatorStatus {
  ACTIVE
  WITHDRAWN

  @@map("adjudicator_status")
}

enum ParticipantEligibility {
  ELIGIBLE
  INELIGIBLE

  @@map("participant_eligibility")
}

model TournamentInstitution {
  id                    String   @id @default(cuid())
  tournamentId          String   @map("tournament_id")
  name                  String
  aliases               String[] @default([])
  logoUrl               String?  @map("logo_url")
  contactName           String?  @map("contact_name")
  contactEmail          String?  @map("contact_email")
  contactPhone          String?  @map("contact_phone")
  teamsIntended         Int?     @map("teams_intended")
  adjudicatorsIntended  Int?     @map("adjudicators_intended")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tournament       Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams            Team[]
  participants     Participant[]
  adjudicators     Adjudicator[]
  portalTokens     InstitutionPortalToken[]
  aliasRecords     InstitutionAlias[]
  claim            InstitutionClaim?
  invoice          Invoice?
  requests         Request[]
  announcementTargets AnnouncementTarget[]

  @@unique([tournamentId, name])
  @@index([tournamentId])
  @@map("tournament_institutions")
}

model InstitutionAlias {
  id                       String   @id @default(cuid())
  tournamentId             String   @map("tournament_id")
  alias                    String
  resolvedInstitutionId    String   @map("resolved_institution_id")
  createdAt                DateTime @default(now()) @map("created_at")

  tournament            Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  resolvedInstitution   TournamentInstitution @relation(fields: [resolvedInstitutionId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, alias])
  @@index([resolvedInstitutionId])
  @@map("institution_aliases")
}

model Team {
  id                       String   @id @default(cuid())
  tournamentInstitutionId  String   @map("tournament_institution_id")
  name                     String
  isNovice                 Boolean  @default(false) @map("is_novice")
  importPhase              String   @map("import_phase")
  warningFlags             String[] @default([]) @map("warning_flags")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  institution     TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)
  participants    Participant[]
  validationFlags TeamValidationFlag[]

  @@unique([tournamentInstitutionId, name])
  @@index([tournamentInstitutionId])
  @@map("teams")
}

model Participant {
  id                       String   @id @default(cuid())
  tournamentInstitutionId  String   @map("tournament_institution_id")
  teamId                   String?  @map("team_id")
  displayName              String   @map("display_name")
  email                    String?
  phone                    String?
  eligibility              ParticipantEligibility @default(ELIGIBLE)
  ineligibilityReason      String?  @map("ineligibility_reason")
  importPhase              String   @map("import_phase")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  institution   TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)
  team          Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([tournamentInstitutionId])
  @@index([teamId])
  @@index([email])
  @@map("participants")
}

model Adjudicator {
  id                       String            @id @default(cuid())
  tournamentId             String            @map("tournament_id")
  tournamentInstitutionId  String?           @map("tournament_institution_id")
  displayName              String            @map("display_name")
  email                    String?
  phone                    String?
  experienceLevel          String?           @map("experience_level")
  availabilityNotes        String?           @map("availability_notes")
  directorNotes            String?           @map("director_notes")
  status                   AdjudicatorStatus @default(ACTIVE)
  importPhase              String            @map("import_phase")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")

  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  institution  TournamentInstitution? @relation(fields: [tournamentInstitutionId], references: [id], onDelete: SetNull)

  @@index([tournamentId])
  @@index([tournamentInstitutionId])
  @@index([email])
  @@map("adjudicators")
}

model CsvImport {
  id            String          @id @default(cuid())
  tournamentId  String          @map("tournament_id")
  phaseLabel    String          @map("phase_label")
  uploaderId    String          @map("uploader_id")
  storagePath   String          @map("storage_path")
  status        CsvImportStatus @default(STAGING)
  mappingJson   Json?           @map("mapping_json")
  summaryJson   Json?           @map("summary_json")
  createdAt     DateTime        @default(now()) @map("created_at")
  finalizedAt   DateTime?       @map("finalized_at")

  tournament  Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  uploader    Profile          @relation(fields: [uploaderId], references: [id])
  rows        CsvImportRow[]

  @@index([tournamentId])
  @@index([status])
  @@map("csv_imports")
}

model CsvImportRow {
  id         String             @id @default(cuid())
  importId   String             @map("import_id")
  rowIndex   Int                @map("row_index")
  rawJson    Json               @map("raw_json")
  status     CsvImportRowStatus @default(PENDING)
  messages   String[]           @default([])
  createdAt  DateTime           @default(now()) @map("created_at")

  import CsvImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([importId, rowIndex])
  @@index([importId])
  @@map("csv_import_rows")
}

model ColumnMapping {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  name         String
  mappingJson  Json     @map("mapping_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@map("column_mappings")
}

model InstitutionPortalToken {
  id                       String    @id @default(cuid())
  tournamentInstitutionId  String    @map("tournament_institution_id")
  token                    String    @unique
  active                   Boolean   @default(true)
  regeneratedAt            DateTime? @map("regenerated_at")
  disabledAt               DateTime? @map("disabled_at")
  createdAt                DateTime  @default(now()) @map("created_at")

  institution TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)

  @@index([tournamentInstitutionId])
  @@index([active])
  @@map("institution_portal_tokens")
}

enum TeamValidationKind {
  INCOMPLETE
  INELIGIBLE_SPEAKER
  MISSING_JUDGE

  @@map("team_validation_kind")
}

model InstitutionClaim {
  tournamentInstitutionId String   @id @map("tournament_institution_id")
  profileId               String   @map("profile_id")
  claimedAt               DateTime @default(now()) @map("claimed_at")

  institution TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)
  profile     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("institution_claims")
}

model TeamValidationFlag {
  id       String             @id @default(cuid())
  teamId   String             @map("team_id")
  kind     TeamValidationKind
  note     String
  createdAt DateTime          @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, kind])
  @@index([teamId])
  @@map("team_validation_flags")
}

enum PaymentMethod {
  BANK_TRANSFER
  GCASH
  CHECK
  CASH
  OTHER

  @@map("payment_method")
}

enum ReceiptStatus {
  SUBMITTED
  APPROVED
  REJECTED

  @@map("receipt_status")
}

enum InvoiceLineKind {
  TEAM_FEE
  ADJUDICATOR_FEE
  FLAT_FEE

  @@map("invoice_line_kind")
}

model Invoice {
  id                       String   @id @default(cuid())
  tournamentInstitutionId  String   @unique @map("tournament_institution_id")
  invoiceNumber            String   @unique @map("invoice_number")
  subtotalMinor            Int      @default(0) @map("subtotal_minor")
  discountMinor            Int      @default(0) @map("discount_minor")
  discountReason           String?  @map("discount_reason")
  totalMinor               Int      @default(0) @map("total_minor")
  currency                 String   @db.Char(3)
  overrideMinor            Int?     @map("override_minor")
  overrideReason           String?  @map("override_reason")
  overrideById             String?  @map("override_by_id")
  overrideAt               DateTime? @map("override_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  institution              TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)
  overrideBy               Profile? @relation("InvoiceOverrideBy", fields: [overrideById], references: [id], onDelete: SetNull)
  lineItems                InvoiceLineItem[]
  receipts                 PaymentReceipt[]
  reminderLogs             PaymentReminderLog[]

  @@map("invoices")
}

model InvoiceLineItem {
  id             String          @id @default(cuid())
  invoiceId      String          @map("invoice_id")
  kind           InvoiceLineKind
  label          String
  quantity       Int             @default(1)
  unitPriceMinor Int             @map("unit_price_minor")
  subtotalMinor  Int             @map("subtotal_minor")
  createdAt      DateTime        @default(now()) @map("created_at")

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model PaymentReceipt {
  id                String        @id @default(cuid())
  invoiceId         String        @map("invoice_id")
  uploaderId        String        @map("uploader_id")
  amountMinor       Int           @map("amount_minor")
  paymentDate       DateTime      @map("payment_date")
  referenceNumber   String        @map("reference_number")
  method            PaymentMethod
  storagePath       String        @map("storage_path")
  status            ReceiptStatus @default(SUBMITTED)
  verifiedById      String?       @map("verified_by_id")
  verifiedAt        DateTime?     @map("verified_at")
  rejectionReason   String?       @map("rejection_reason")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  invoice           Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploader          Profile       @relation("ReceiptUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  verifiedBy        Profile?      @relation("ReceiptVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([invoiceId, status])
  @@index([status, createdAt])
  @@map("payment_receipts")
}

model PaymentReminderLog {
  id                String   @id @default(cuid())
  invoiceId         String   @map("invoice_id")
  sentById          String   @map("sent_by_id")
  sentAt            DateTime @default(now()) @map("sent_at")

  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sentBy            Profile  @relation("ReminderSender", fields: [sentById], references: [id], onDelete: Restrict)

  @@index([invoiceId, sentAt(sort: Desc)])
  @@map("payment_reminder_logs")
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  RETRACTED
  @@map("announcement_status")
}

enum RequestType {
  TEAM_ADDITION
  TEAM_WITHDRAWAL
  SPEAKER_REPLACEMENT
  ADJUDICATOR_ADD
  ADJUDICATOR_REMOVE
  INSTITUTION_INFO_UPDATE
  BILLING_QUESTION
  DEADLINE_EXTENSION
  ACCESSIBILITY_ACCOMMODATION
  DIETARY_ACCOMMODATION
  EQUIPMENT_REQUEST
  RULES_CLARIFICATION
  OTHER
  @@map("request_type")
}

enum RequestStatus {
  PENDING
  MORE_INFO
  APPROVED
  REJECTED
  @@map("request_status")
}

enum RequestActivityKind {
  SUBMITTED
  COMMENT
  MORE_INFO_REQUESTED
  MORE_INFO_PROVIDED
  APPROVED
  REJECTED
  APPROVAL_ATTEMPT_FAILED
  @@map("request_activity_kind")
}

model Announcement {
  id               String              @id @default(cuid())
  tournamentId     String              @map("tournament_id")
  authorId         String              @map("author_id")
  title            String
  bodyHtml         String              @map("body_html")
  attachmentPath   String?             @map("attachment_path")
  status           AnnouncementStatus  @default(DRAFT)
  isAllInstitutions Boolean            @default(false) @map("is_all_institutions")
  isPublic         Boolean             @default(false) @map("is_public")
  scheduledFor     DateTime?           @map("scheduled_for")
  publishedAt      DateTime?           @map("published_at")
  editedAt         DateTime?           @map("edited_at")
  retractionNote   String?             @map("retraction_note")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  tournament       Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  author           Profile             @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  targets          AnnouncementTarget[]
  reads            AnnouncementRead[]

  @@index([tournamentId, status, publishedAt(sort: Desc)])
  @@map("announcements")
}

model AnnouncementTarget {
  announcementId          String                 @map("announcement_id")
  tournamentInstitutionId String                 @map("tournament_institution_id")

  announcement            Announcement           @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  institution             TournamentInstitution  @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)

  @@id([announcementId, tournamentInstitutionId])
  @@index([tournamentInstitutionId])
  @@map("announcement_targets")
}

model AnnouncementRead {
  announcementId String       @map("announcement_id")
  profileId      String       @map("profile_id")
  readAt         DateTime     @default(now()) @map("read_at")

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  profile        Profile      @relation("AnnouncementReader", fields: [profileId], references: [id], onDelete: Cascade)

  @@id([announcementId, profileId])
  @@index([profileId, readAt(sort: Desc)])
  @@map("announcement_reads")
}

model Request {
  id                       String                @id @default(cuid())
  tournamentId             String                @map("tournament_id")
  tournamentInstitutionId  String                @map("tournament_institution_id")
  submitterId              String                @map("submitter_id")
  sequenceNumber           Int                   @map("sequence_number")
  type                     RequestType
  status                   RequestStatus         @default(PENDING)
  description              String
  payload                  Json
  attachmentPath           String?               @map("attachment_path")
  resolvedById             String?               @map("resolved_by_id")
  resolvedAt               DateTime?             @map("resolved_at")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  tournament    Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  institution   TournamentInstitution @relation(fields: [tournamentInstitutionId], references: [id], onDelete: Cascade)
  submitter     Profile               @relation("RequestSubmitter", fields: [submitterId], references: [id], onDelete: Restrict)
  resolvedBy    Profile?              @relation("RequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  activities    RequestActivity[]

  @@unique([tournamentId, sequenceNumber])
  @@index([tournamentId, status, createdAt(sort: Desc)])
  @@index([tournamentInstitutionId, status])
  @@map("requests")
}

model RequestActivity {
  id         String                @id @default(cuid())
  requestId  String                @map("request_id")
  actorId    String                @map("actor_id")
  kind       RequestActivityKind
  note       String?
  createdAt  DateTime              @default(now()) @map("created_at")

  request    Request               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor      Profile               @relation("RequestActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([requestId, createdAt])
  @@map("request_activities")
}

enum ActivityAction {
  ORG_CREATED
  ORG_UPDATED
  ORG_DELETED
  ORG_MEMBER_INVITED
  ORG_MEMBER_INVITE_ACCEPTED
  ORG_MEMBER_INVITE_DECLINED
  ORG_MEMBER_REMOVED
  ORG_OWNERSHIP_TRANSFERRED
  TOURNAMENT_CREATED
  TOURNAMENT_UPDATED
  TOURNAMENT_ARCHIVED
  TOURNAMENT_UNARCHIVED
  TOURNAMENT_DIRECTOR_ADDED
  TOURNAMENT_DIRECTOR_REMOVED
  CSV_IMPORT_STARTED
  CSV_IMPORT_MAPPED
  CSV_IMPORT_PROCESSED
  CSV_IMPORT_NORMALIZATION_CONFIRMED
  CSV_IMPORT_DIFF_APPLIED
  CSV_IMPORT_FINALIZED
  CSV_IMPORT_ROLLED_BACK
  PORTAL_CLAIMED
  PORTAL_TOKEN_REGENERATED
  PORTAL_DISABLED
  INSTITUTION_UPDATED
  TEAM_CREATED
  TEAM_UPDATED
  TEAM_WITHDRAWN
  PARTICIPANT_UPDATED
  ADJUDICATOR_UPDATED
  INVOICE_GENERATED
  INVOICE_DISCOUNT_APPLIED
  INVOICE_OVERRIDE_APPLIED
  INVOICE_OVERRIDE_CLEARED
  RECEIPT_SUBMITTED
  RECEIPT_APPROVED
  RECEIPT_REJECTED
  REMINDER_SENT
  ANNOUNCEMENT_CREATED
  ANNOUNCEMENT_UPDATED
  ANNOUNCEMENT_PUBLISHED
  ANNOUNCEMENT_SCHEDULED
  ANNOUNCEMENT_RETRACTED
  REQUEST_SUBMITTED
  REQUEST_MORE_INFO_REQUESTED
  REQUEST_MORE_INFO_PROVIDED
  REQUEST_APPROVED
  REQUEST_REJECTED

  @@map("activity_action")
}

model ActivityLog {
  id                String         @id @default(cuid())
  tournamentId      String?        @map("tournament_id")
  orgId             String?        @map("org_id")
  actorId           String?        @map("actor_id")
  actorRoleAtTime   String         @map("actor_role_at_time")
  action            ActivityAction
  resourceType      String         @map("resource_type")
  resourceId        String?        @map("resource_id")
  description       String
  beforeSnapshot    Json?          @map("before_snapshot")
  afterSnapshot     Json?          @map("after_snapshot")
  createdAt         DateTime       @default(now()) @map("created_at")

  tournament        Tournament?    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  organization      Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor             Profile?       @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tournamentId, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("activity_log")
}

enum PublicAssetKind {
  RULES
  INFO_PACK
  TAB_GUIDE
  CODE_OF_CONDUCT
  @@map("public_asset_kind")
}

enum NotificationCategory {
  ANNOUNCEMENTS
  PAYMENT_UPDATES
  REQUEST_UPDATES
  CALENDAR_NUDGES
  TRANSACTIONAL
  @@map("notification_category")
}

model TournamentPublicAsset {
  id            String          @id @default(cuid())
  tournamentId  String          @map("tournament_id")
  kind          PublicAssetKind
  storagePath   String          @map("storage_path")
  label         String
  createdAt     DateTime        @default(now()) @map("created_at")

  tournament    Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, kind])
  @@map("tournament_public_assets")
}

model TournamentContact {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  name         String
  email        String
  socialLinks  Json?      @map("social_links")

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@map("tournament_contacts")
}

model PublicContactMessage {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  senderName   String     @map("sender_name")
  senderEmail  String     @map("sender_email")
  body         String
  senderIp     String?    @map("sender_ip")
  createdAt    DateTime   @default(now()) @map("created_at")

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, createdAt(sort: Desc)])
  @@map("public_contact_messages")
}

model UserEmailPreference {
  id              String   @id @default(cuid())
  profileId       String   @unique @map("profile_id")
  announcements   Boolean  @default(true)
  paymentUpdates  Boolean  @default(true) @map("payment_updates")
  requestUpdates  Boolean  @default(true) @map("request_updates")
  calendarNudges  Boolean  @default(true) @map("calendar_nudges")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("user_email_preferences")
}
